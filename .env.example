# Database
DATABASE_URL="postgresql://guildsites:guildsites@localhost:5432/guildsites?schema=public"

# Auth.js
AUTH_SECRET="replace-with-long-random"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# Discord OAuth (per org/app)
# Burning Man app callback: http://localhost:3000/api/auth/callback/discord-burningman
DISCORD_CLIENT_ID_BURNINGMAN="replace-with-discord-client-id"
DISCORD_CLIENT_SECRET_BURNINGMAN="replace-with-discord-client-secret"
# Optional bot token for role-gating
DISCORD_BOT_TOKEN_BURNINGMAN="replace-with-discord-bot-token"

# Ren Faire app callback: http://localhost:3000/api/auth/callback/discord-renfaire
DISCORD_CLIENT_ID_RENFAIRE="replace-with-discord-client-id"
DISCORD_CLIENT_SECRET_RENFAIRE="replace-with-discord-client-secret"
# Optional bot token for role-gating
DISCORD_BOT_TOKEN_RENFAIRE="replace-with-discord-bot-token"


ORG_CONFIG='{
  "burningman": {
    "name": "Camp Whatever",
    "guildId": "DISCORD_GUILD_ID_1",
    "requiredRoleIds": ["OPTIONAL_ROLE_ID"],
    "inviteUrl": "https://discord.gg/xxxx",
    "authProviderId": "discord-burningman"
  },
  "renfaire": {
    "name": "Guild Whatever",
    "guildId": "DISCORD_GUILD_ID_2",
    "requiredRoleIds": [],
    "inviteUrl": "https://discord.gg/yyyy",
    "authProviderId": "discord-renfaire"
  }
}'
